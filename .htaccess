# Redirigir de /p/algo a /view.php?id=algo
Options +FollowSymLinks
RewriteEngine On

# Detectar si estamos en una subcarpeta y ajustar la reescritura
RewriteCond %{REQUEST_URI} ^/(.*)/p/([a-zA-Z0-9_-]+)/?$
RewriteRule ^p/([a-zA-Z0-9_-]+)/?$ view.php?id=$1 [L,NC,QSA]

# Si el request es para /p/(slug) en la raíz
RewriteRule ^p/([a-zA-Z0-9_-]+)/?$ view.php?id=$1 [L,NC,QSA]

# Prevenir acceso estricto a archivos base de datos (por si se ubican en root)
<FilesMatch "\.sqlite$">
    Require all denied
</FilesMatch>
<FilesMatch "\.sqlite3$">
    Require all denied
</FilesMatch>
<FilesMatch "\.db$">
    Require all denied
</FilesMatch>
